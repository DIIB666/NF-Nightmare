{
  "manifest_version": 3,
  "name": "NF Nightmare",
  "version": "2.0",
  "description": "NF Nightmare — break free from household locks.",
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequest",
    "tabs",
    "webNavigation",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.netflix.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "nf-nightmare@dIIb666.dev",
      "strict_min_version": "109.0"
    }
  }
}
